---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SKILL_STACK // TERMINAL_CORE" pageName="stack">
	<main class="stack-main">
		<div class="stack-bg-pattern"></div>
		<div class="stack-bg-scanline"></div>

		<section class="stack-content">
			<div class="stack-hero">
				<div class="stack-hero-meta">
					<div class="status-row">
						<span class="status-dot"></span>
						<span class="status-text">MANIFEST_TYPE: SKILLS_PROFILE</span>
					</div>
					<div class="stack-hero-divider"></div>
				</div>
				<h1 class="stack-hero-title">
					<span class="hero-line-wrap"><span class="hero-line hero-line--1">SKILL_<span style="color: var(--primary);">STACK</span></span></span>
				</h1>
				<p class="stack-hero-desc">Knowledge matrix for day-to-day engineering work, including primary languages, framework fluency, and database systems.</p>
			</div>

			<div class="stack-grid">
				<div class="stack-section stack-section--full stack-section-languages">
					<div class="stack-section-head">
						<h2 class="stack-section-title">LANGUAGES</h2>
						<div class="stack-section-divider"></div>
					</div>
					<div class="module-cards-2col">
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">memory</span>
								<div>
									<h3 class="module-card-sm-name">C++</h3>
									<span class="module-card-sm-subtitle">COMPILED_LANGUAGE</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">GAME DEVELOPMENT</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">10+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">memory_alt</span>
								<div>
									<h3 class="module-card-sm-name">C#</h3>
									<span class="module-card-sm-subtitle">APP_AND_BACKEND</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">APPLICATIONS</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">20+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">javascript</span>
								<div>
									<h3 class="module-card-sm-name">JavaScript</h3>
									<span class="module-card-sm-subtitle">WEB_LANGUAGE_CORE</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">FRONTEND</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">15+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">dns</span>
								<div>
									<h3 class="module-card-sm-name">Node</h3>
									<span class="module-card-sm-subtitle">JS_RUNTIME</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">BACKEND</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">7+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">settings_suggest</span>
								<div>
									<h3 class="module-card-sm-name">PHP</h3>
									<span class="module-card-sm-subtitle">SERVER_SIDE_WEB</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">BACKEND</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">15+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">description</span>
								<div>
									<h3 class="module-card-sm-name">HTML</h3>
									<span class="module-card-sm-subtitle">DOCUMENT_STRUCTURE</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">MARKUP</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">25+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">format_paint</span>
								<div>
									<h3 class="module-card-sm-name">CSS</h3>
									<span class="module-card-sm-subtitle">STYLING_SYSTEM</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">UI_STYLING</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">15+</span></div>
							</div>
						</div>
					</div>
				</div>

				<div class="stack-section stack-section--8 stack-section-frameworks">
					<div class="stack-section-head">
						<h2 class="stack-section-title">FRAMEWORKS</h2>
						<div class="stack-section-divider"></div>
					</div>
					<div class="module-cards-2col">
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">deployed_code</span>
								<div>
									<h3 class="module-card-sm-name">React</h3>
									<span class="module-card-sm-subtitle">COMPONENT_FRAMEWORK</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">COMPONENT_UI</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">6+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">travel_explore</span>
								<div>
									<h3 class="module-card-sm-name">Astro</h3>
									<span class="module-card-sm-subtitle">CONTENT_SITE_FRAMEWORK</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">STATIC_GENERATION</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">2+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">web</span>
								<div>
									<h3 class="module-card-sm-name">Vue</h3>
									<span class="module-card-sm-subtitle">REACTIVE_FRAMEWORK</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">COMPONENT_MODEL</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">2+</span></div>
							</div>
						</div>
						<div class="module-card-sm">
							<div class="module-card-sm-header">
								<span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">extension</span>
								<div>
									<h3 class="module-card-sm-name">Allegro</h3>
									<span class="module-card-sm-subtitle">GRAPHICS_FRAMEWORK</span>
								</div>
							</div>
							<div class="module-stat-rows">
								<div class="module-stat-row"><span class="stat-row-key">FOCUS</span><span class="stat-row-val">GAME_DEVELOPMENT</span></div>
								<div class="module-stat-row"><span class="stat-row-key">YEARS</span><span class="stat-row-val primary">10+</span></div>
							</div>
						</div>
					</div>
				</div>

				<div class="stack-section stack-section--4">
					<div class="stack-section-head">
						<h2 class="stack-section-title">DATABASE</h2>
						<div class="stack-section-divider"></div>
					</div>
					<div class="data-card">
						<div class="data-card-bg-icon">
							<span class="material-symbols-outlined" style="font-size: 200px; font-variation-settings: 'FILL' 1;">database</span>
						</div>
						<div class="data-card-content">
							<div class="db-entry">
								<div class="db-icon" style="border-color: var(--primary);">
									<span class="material-symbols-outlined" style="font-size: 16px; color: var(--primary);">database</span>
								</div>
								<div class="db-info">
									<div class="db-name">SQL</div>
									<div class="db-label">MYSQL, POSTGRESQL, SQL SERVER, SQLITE</div>
								</div>
								<div class="db-version">4 TECH</div>
							</div>
							<div class="db-entry">
								<div class="db-icon" style="border-color: var(--secondary);">
									<span class="material-symbols-outlined" style="font-size: 16px; color: var(--secondary);">bolt</span>
								</div>
								<div class="db-info">
									<div class="db-name">NO-SQL</div>
									<div class="db-label">MONGODB, FIREBASE</div>
								</div>
								<div class="db-version secondary">2 TECH</div>
							</div>
							<div class="latency-block">
								<div class="latency-header">
									<span class="latency-key">DATABASE_SCOPE</span>
									<span class="latency-val">6 TECHNOLOGIES</span>
								</div>
								<div class="latency-track">
									<div class="latency-fill" style="width: 96%;"></div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="stack-section stack-section--full stack-section-additional">
					<div class="stack-section-head">
						<h2 class="stack-section-title">ADDITIONAL_SKILLS</h2>
						<div class="stack-section-divider"></div>
					</div>
					<div class="module-cards-2col">
						<div class="module-card-sm"><div class="module-card-sm-header"><span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">blur_on</span><div><h3 class="module-card-sm-name">OpenGL</h3><span class="module-card-sm-subtitle">GRAPHICS_API</span></div></div></div>
						<div class="module-card-sm"><div class="module-card-sm-header"><span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">gradient</span><div><h3 class="module-card-sm-name">GLSL</h3><span class="module-card-sm-subtitle">SHADER_LANGUAGE</span></div></div></div>
						<div class="module-card-sm"><div class="module-card-sm-header"><span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">auto_awesome_motion</span><div><h3 class="module-card-sm-name">HLSL</h3><span class="module-card-sm-subtitle">SHADER_LANGUAGE</span></div></div></div>
						<div class="module-card-sm"><div class="module-card-sm-header"><span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">developer_board</span><div><h3 class="module-card-sm-name">Visual Studio</h3><span class="module-card-sm-subtitle">IDE_TOOLING</span></div></div></div>
						<div class="module-card-sm"><div class="module-card-sm-header"><span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">account_tree</span><div><h3 class="module-card-sm-name">Node-RED</h3><span class="module-card-sm-subtitle">FLOW_PROGRAMMING</span></div></div></div>
						<div class="module-card-sm"><div class="module-card-sm-header"><span class="material-symbols-outlined" style="font-size: 28px; color: var(--secondary);">draw</span><div><h3 class="module-card-sm-name">UI/UX</h3><span class="module-card-sm-subtitle">PRODUCT_DESIGN</span></div></div></div>
					</div>
				</div>

				<div class="stack-section stack-section--full stack-section--mt">
					<div class="metrics-grid">
						<div class="metric-cell"><span class="metric-label">languages</span><span class="metric-value">7</span></div>
						<div class="metric-cell"><span class="metric-label">frameworks</span><span class="metric-value">4</span></div>
						<div class="metric-cell"><span class="metric-label">databases</span><span class="metric-value">6</span></div>
						<div class="metric-cell"><span class="metric-label">total_skills</span><span class="metric-value">23</span></div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<div class="stack-corner-deco"></div>
</Layout>