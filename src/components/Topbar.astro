---
---

<header class="topbar">
	<div class="topbar-left">
		<span class="topbar-title">TERMINAL_CORE</span>
		<span class="topbar-divider"></span>
		<span class="topbar-location">LOC: 44.2619° N, 88.4154° W</span>
	</div>

	<div class="topbar-right">
		<div class="search-box">
			<span class="material-symbols-outlined" style="font-size: 18px; color: var(--outline);">search</span>
			<input class="search-input" placeholder="SEARCH_FILES..." type="text" />
		</div>

		<div class="topbar-icons">
			<span class="material-symbols-outlined icon-btn">terminal</span>
			<div class="theme-menu-wrap">
				<span
					class="material-symbols-outlined icon-btn"
					id="theme-toggle-btn"
					role="button"
					tabindex="0"
					aria-label="Theme menu"
					aria-expanded="false"
					aria-controls="theme-menu"
					title="Theme"
				>settings_input_component</span>

				<div class="theme-menu" id="theme-menu" role="menu" aria-label="Theme selector" hidden>
					<button type="button" class="theme-menu-item" data-theme-value="system" role="menuitem">
						<span class="material-symbols-outlined">desktop_windows</span>
						<span>System</span>
					</button>
					<button type="button" class="theme-menu-item" data-theme-value="dark" role="menuitem">
						<span class="material-symbols-outlined">dark_mode</span>
						<span>Dark</span>
					</button>
					<button type="button" class="theme-menu-item" data-theme-value="light" role="menuitem">
						<span class="material-symbols-outlined">light_mode</span>
						<span>Light</span>
					</button>
				</div>
			</div>
		</div>
	</div>
</header>
